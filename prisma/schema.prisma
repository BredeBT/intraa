generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrgType {
  COMPANY
  COMMUNITY
}

enum OrgPlan {
  FREE
  PRO
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MODERATOR
  VIP
  MEMBER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  WAITING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketSource {
  INTERNAL
  SUPPORT
}

enum ShopItemType {
  BADGE
  NAME_COLOR
  CHAT_EFFECT
  PROFILE_FRAME
  VIP_ROLE
}

enum ChannelType {
  TEXT
  DIRECT
  STREAM
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum InvitationRole {
  ADMIN
  MEMBER
}

enum NotifType {
  MESSAGE
  TICKET
  COMMENT
  USER
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  DECLINED
  BLOCKED
}

enum ReportReason {
  HARASSMENT
  HATE_SPEECH
  SPAM
  INAPPROPRIATE
  THREATS
  IMPERSONATION
  CHEATING
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  type        OrgType
  plan        OrgPlan  @default(FREE)
  joinType        String   @default("OPEN")
  visibility      String   @default("open")  // "open" | "closed" | "private"
  openInviteToken String?  @unique
  createdAt       DateTime @default(now())

  memberships    Membership[]
  posts          Post[]
  channels       Channel[]
  tickets        Ticket[]
  files          File[]
  invitations    Invitation[]
  notifications  Notification[]
  userActivities UserActivity[]
  follows        Follow[]
  features       OrganizationFeature[]
  theme                  TenantTheme?
  streamSettings         StreamSettings?
  streamSessions         StreamSession[]
  profileSidebarSettings ProfileSidebarSettings?
  clickerProfiles        ClickerProfile[]
  clickerUpgrades        ClickerUpgrade[]
  clickerEvents          ClickerEvent[]
  fanPasses              FanPass[]
  chessGames             ChessGame[]
  chessInvites           ChessInvite[]
  chessProfiles          ChessProfile[]
  coinTransactions       CoinTransaction[]
  shopItems              ShopItem[]
  shopPurchases          ShopPurchase[]
  ticketCategories       TicketCategory[]
  agentCategories        AgentCategory[]
  userReports            UserReport[]
}

model TenantTheme {
  id              String  @id @default(cuid())
  organizationId  String  @unique
  logoUrl         String?
  bannerUrl       String?
  bannerPreset    String?
  avatarPreset    String?
  welcomeMessage  String?
  fontStyle       String  @default("default")
  borderRadius    String  @default("rounded-lg")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model OrganizationFeature {
  id             String   @id @default(cuid())
  organizationId String
  feature        String
  enabled        Boolean  @default(true)
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, feature])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  username      String    @unique
  avatarUrl     String?
  bannerUrl     String?
  image         String?
  emailVerified DateTime?
  password      String?
  isSuperAdmin  Boolean   @default(false)
  isPublic      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  bio           String?
  interests     String[]
  website       String?
  socialLinks   Json?
  status          String?   @default("online")
  lastActive      DateTime?
  termsAcceptedAt      DateTime?
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  emailConsent         Boolean   @default(true)

  memberships             Membership[]
  posts                   Post[]
  comments                Comment[]
  likes                   Like[]
  messages                Message[]
  messageReactions        MessageReaction[]
  authoredTickets         Ticket[]       @relation("TicketAuthor")
  assignedTickets         Ticket[]       @relation("TicketAssignee")
  ticketReplies           TicketReply[]
  uploadedFiles           File[]
  accounts                Account[]
  sessions                Session[]
  sentInvitations         Invitation[]   @relation("InvitedBy")
  notifications           Notification[]
  userActivities          UserActivity[]
  following               Follow[]       @relation("Follower")
  followers               Follow[]       @relation("Following")
  notificationPreference  NotificationPreference?
  clickerProfiles         ClickerProfile[]
  clickerUpgrades         ClickerUpgrade[]
  fanPasses               FanPass[]
  coinTransactions        CoinTransaction[]
  shopPurchases           ShopPurchase[]
  agentCategories         AgentCategory[]
  friendsSent             Friendship[]    @relation("FriendshipSender")
  friendsReceived         Friendship[]    @relation("FriendshipReceiver")
  dmsSent                 DirectMessage[] @relation("DMSender")
  dmsReceived             DirectMessage[] @relation("DMReceiver")
  groupChatsCreated       GroupChat[]     @relation("GroupChatCreator")
  groupChatMemberships    GroupChatMember[]
  groupMessages           GroupMessage[]
  channelReads            ChannelRead[]
  reportsReceived         UserReport[]    @relation("ReportedUser")
  reportsMade             UserReport[]    @relation("ReportedBy")
  fanpassWaitlist         FanpassWaitlist?
  pushSubscriptions       PushSubscription[]
  chessProfiles           ChessProfile[]
  chessGamesAsWhite       ChessGame[]      @relation("ChessWhite")
  chessGamesAsBlack       ChessGame[]      @relation("ChessBlack")
  chessMessages           ChessMessage[]
  chessInvitesSent        ChessInvite[]    @relation("ChessInviteSender")
  chessInvitesReceived    ChessInvite[]    @relation("ChessInviteReceiver")

  @@index([username])
}

model NotificationPreference {
  id              String  @id @default(cuid())
  userId          String  @unique
  emailOnMessage  Boolean @default(true)
  emailOnTicket   Boolean @default(true)
  emailOnComment  Boolean @default(true)
  emailOnMention  Boolean @default(true)
  emailOnFile     Boolean @default(false)
  pushOnMessage   Boolean @default(true)
  pushOnTicket    Boolean @default(false)
  pushOnComment   Boolean @default(false)
  pushOnMention   Boolean @default(true)
  pushOnFile      Boolean @default(false)
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Membership {
  id             String       @id @default(cuid())
  role           MemberRole   @default(MEMBER)
  points         Int          @default(0)
  userId         String
  organizationId String
  username       String?
  isAgent        Boolean      @default(false)
  isBanned       Boolean      @default(false)
  bannedAt       DateTime?
  bannedBy       String?

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@unique([organizationId, username])
  @@index([organizationId, userId])
}

model Post {
  id        String   @id @default(cuid())
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())
  orgId     String
  authorId  String

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  author       User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments     Comment[]
  likes        Like[]

  @@index([orgId, createdAt(sort: Desc)])
}

model Like {
  id             String   @id @default(cuid())
  postId         String
  userId         String
  organizationId String
  createdAt      DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())
  postId    String
  authorId  String

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
}

model Channel {
  id        String      @id @default(cuid())
  name      String
  type      ChannelType @default(TEXT)
  orgId     String

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  messages     Message[]
  channelReads ChannelRead[]

  @@unique([orgId, name])
}

model ChannelRead {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  readAt    DateTime @default(now())

  user    User    @relation(fields: [userId],    references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
}

model Message {
  id              String    @id @default(cuid())
  content         String
  imageUrl        String?
  createdAt       DateTime  @default(now())
  editedAt        DateTime?
  isPinned        Boolean   @default(false)
  channelId       String
  authorId        String
  parentMessageId String?

  channel   Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Message?          @relation("Replies", fields: [parentMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   Message[]         @relation("Replies")
  reactions MessageReaction[]

  @@index([channelId, createdAt(sort: Desc)])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Ticket {
  id           String         @id @default(cuid())
  orgId        String
  authorId     String
  assigneeId   String?
  title        String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(NORMAL)
  categoryId   String?
  source       TicketSource   @default(INTERNAL)
  fromTenantId String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  replies      TicketReply[]
  organization Organization    @relation(fields: [orgId],        references: [id], onDelete: Cascade)
  author       User            @relation("TicketAuthor",         fields: [authorId],   references: [id])
  assignee     User?           @relation("TicketAssignee",       fields: [assigneeId], references: [id])
  category     TicketCategory? @relation(fields: [categoryId], references: [id])

  @@index([orgId, status, createdAt(sort: Desc)])
}

model TicketReply {
  id        String   @id @default(cuid())
  ticketId  String
  authorId  String
  content   String
  isAgent   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author User   @relation(fields: [authorId], references: [id])

  @@index([ticketId, createdAt(sort: Desc)])
}

model TicketCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  color          String   @default("#6366f1")
  emoji          String   @default("📋")
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tickets      Ticket[]
  agentAccess  AgentCategory[]

  @@unique([organizationId, name])
}

model AgentCategory {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  categoryId     String
  assignedAt     DateTime @default(now())

  user         User           @relation(fields: [userId],         references: [id], onDelete: Cascade)
  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     TicketCategory @relation(fields: [categoryId],     references: [id], onDelete: Cascade)

  @@unique([userId, categoryId])
}

model File {
  id         String   @id @default(cuid())
  name       String
  url        String
  size       Int
  createdAt  DateTime @default(now())
  orgId      String
  uploaderId String

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  uploader     User         @relation(fields: [uploaderId], references: [id], onDelete: Cascade)
}

model Invitation {
  id             String           @id @default(cuid())
  email          String
  role           InvitationRole   @default(MEMBER)
  status         InvitationStatus @default(PENDING)
  token          String           @unique @default(cuid())
  organizationId String
  invitedById    String
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime         @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)
}

model Notification {
  id             String    @id @default(cuid())
  type           NotifType
  title          String
  body           String
  href           String
  createdAt      DateTime  @default(now())
  readAt         DateTime?
  userId         String
  organizationId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

model UserActivity {
  id             String   @id @default(cuid())
  action         String
  points         Int
  createdAt      DateTime @default(now())
  userId         String
  organizationId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model StreamSession {
  id             String    @id @default(cuid())
  organizationId String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model StreamSettings {
  id                String  @id @default(cuid())
  organizationId    String  @unique
  twitchChannel     String?
  youtubeChannel    String?
  preferredPlatform String  @default("twitch")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Follow {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  followerId     String
  followingId    String
  organizationId String

  follower     User         @relation("Follower",  fields: [followerId],  references: [id], onDelete: Cascade)
  following    User         @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId, organizationId])
}

model ProfileSidebarSettings {
  id               String  @id @default(cuid())
  organizationId   String  @unique
  showStatus       Boolean @default(true)
  showBio          Boolean @default(true)
  showWebsite      Boolean @default(true)
  showSocials      Boolean @default(true)
  showStats        Boolean @default(true)
  showMemberCount  Boolean @default(true)
  showPostCount    Boolean @default(true)
  showCreatedAt    Boolean @default(true)
  showStreamStatus Boolean @default(true)
  customTitle      String?
  customText       String?
  showCustomText   Boolean @default(false)
  showTopPoints    Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model ClickerProfile {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  coins             Float    @default(0)
  allTimeHighCoins  Float    @default(0)
  totalClicks       Int      @default(0)
  coinsPerClick  Float    @default(1)
  coinsPerSecond Float    @default(0)
  lastSeen       DateTime @default(now())
  prestigeLevel  Int      @default(0)
  prestigeWorld  Int      @default(1)
  permanentBonus Float    @default(1.0)
  totalPrestige  Int      @default(0)
  prestigeShop       Json     @default("{}")
  prestigePointsSpent Int     @default(0)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId, coins(sort: Desc)])
}

model ClickerUpgrade {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  upgradeId      String
  level          Int      @default(1)
  purchasedAt    DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, upgradeId])
}

model ClickerEvent {
  id             String   @id @default(cuid())
  organizationId String
  type           String
  multiplier     Float    @default(1)
  bonusCoins     Float    @default(0)
  startedAt      DateTime @default(now())
  endsAt         DateTime
  createdBy      String
  active         Boolean  @default(true)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model FanPass {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  status         String    @default("ACTIVE")
  startDate      DateTime  @default(now())
  endDate        DateTime
  paidAmount     Int       @default(59)
  cancelledAt    DateTime?
  createdAt      DateTime  @default(now())

  user         User         @relation(fields: [userId],         references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
}

model CoinTransaction {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  amount         Int
  reason         String
  description    String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId],         references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([userId, organizationId, createdAt(sort: Desc)])
}

model ShopItem {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  description    String?
  type           ShopItemType
  value          String
  coinCost       Int
  fanpassOnly Boolean      @default(false)
  enabled        Boolean      @default(true)
  createdAt      DateTime     @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  purchases    ShopPurchase[]
}

model ShopPurchase {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  shopItemId     String
  coinsPaid      Int
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId],         references: [id], onDelete: Cascade)
  shopItem     ShopItem     @relation(fields: [shopItemId],     references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, shopItemId])
}

model Friendship {
  id         String           @id @default(cuid())
  senderId   String
  receiverId String
  status     FriendshipStatus @default(PENDING)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  sender   User @relation("FriendshipSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("FriendshipReceiver",  fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
}

model DirectMessage {
  id         String    @id @default(cuid())
  senderId   String
  receiverId String
  content    String
  imageUrl   String?
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  sender   User @relation("DMSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver User @relation("DMReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId, createdAt(sort: Desc)])
}

model GroupChat {
  id        String   @id @default(cuid())
  name      String
  createdBy String
  createdAt DateTime @default(now())

  creator  User              @relation("GroupChatCreator", fields: [createdBy], references: [id])
  members  GroupChatMember[]
  messages GroupMessage[]
}

model GroupChatMember {
  id         String    @id @default(cuid())
  groupId    String
  userId     String
  joinedAt   DateTime  @default(now())
  lastReadAt DateTime?

  group GroupChat @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user  User      @relation(fields: [userId],  references: [id])

  @@unique([groupId, userId])
}

model GroupMessage {
  id        String   @id @default(cuid())
  groupId   String
  authorId  String
  content   String
  imageUrl  String?
  createdAt DateTime @default(now())

  group  GroupChat @relation(fields: [groupId],  references: [id], onDelete: Cascade)
  author User      @relation(fields: [authorId], references: [id])
}

model UserReport {
  id             String       @id @default(cuid())
  reportedUserId String
  reportedById   String
  organizationId String
  reason         ReportReason
  description    String?
  status         ReportStatus @default(PENDING)
  reviewedBy     String?
  reviewedAt     DateTime?
  reviewNote     String?
  createdAt      DateTime     @default(now())

  reportedUser User         @relation("ReportedUser", fields: [reportedUserId], references: [id])
  reportedBy   User         @relation("ReportedBy",   fields: [reportedById],   references: [id])
  organization Organization @relation(fields: [organizationId], references: [id])
}

model FanpassWaitlist {
  id        String   @id @default(cuid())
  userId    String   @unique
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChessProfile {
  id      String @id @default(cuid())
  userId  String
  orgId   String
  rating  Int    @default(1200)
  wins    Int    @default(0)
  losses  Int    @default(0)
  draws   Int    @default(0)

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [orgId],  references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
  @@index([orgId, rating(sort: Desc)])
}

model ChessGame {
  id      String @id @default(cuid())
  orgId   String
  whiteId String
  blackId String
  // "active" | "white_wins" | "black_wins" | "draw" | "abandoned"
  status  String @default("active")
  fen     String @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1")
  moves   Json   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  white        User          @relation("ChessWhite", fields: [whiteId], references: [id])
  black        User          @relation("ChessBlack", fields: [blackId], references: [id])
  messages     ChessMessage[]
  invite       ChessInvite?

  @@index([orgId, status, createdAt(sort: Desc)])
}

model ChessMessage {
  id        String   @id @default(cuid())
  gameId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  game   ChessGame @relation(fields: [gameId],   references: [id], onDelete: Cascade)
  author User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([gameId, createdAt(sort: Asc)])
}

model ChessInvite {
  id         String   @id @default(cuid())
  orgId      String
  senderId   String
  receiverId String
  // "pending" | "accepted" | "declined" | "cancelled"
  status     String   @default("pending")
  gameId     String?  @unique
  createdAt  DateTime @default(now())

  organization Organization @relation(fields: [orgId],       references: [id], onDelete: Cascade)
  sender       User         @relation("ChessInviteSender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver     User         @relation("ChessInviteReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  game         ChessGame?   @relation(fields: [gameId],      references: [id])

  @@index([orgId, status, createdAt(sort: Desc)])
}
